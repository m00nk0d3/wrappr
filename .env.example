# PostgreSQL
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
# e.g. postgres://user:password@localhost:5432/wrappr
DATABASE_URL=

# Redis
# No auth in local dev — add requirepass if you need it
# e.g. redis://localhost:6379
REDIS_URL=

# Gotenberg
# e.g. http://localhost:3000
GOTENBERG_URL=

# Server
PORT=

# Email (Resend)
RESEND_API_KEY=

# JWT
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=

# App
APP_URL=http://localhost:3001

# Web / Next.js dashboard
NEXT_PUBLIC_API_URL=http://localhost:8080
